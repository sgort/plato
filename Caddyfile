# Replace yourdomain.nl with your actual domain.
# For local dev, use :80 and comment out the HTTPS block.
yourdomain.nl {
  handle /api/* {
    reverse_proxy api:8000
  }
  handle {
    reverse_proxy frontend:80
  }
}

