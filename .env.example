# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (default, no server needed — SQLite file created automatically):
# DATABASE_URL=sqlite+aiosqlite:///./dashboard.db

# Production / Docker:
# DATABASE_URL=postgresql+asyncpg://dashboard:dashboard@db:5432/dashboard

# ── Redis ─────────────────────────────────────────────────────────────────────
# Optional — app works without it, just no caching.
# REDIS_URL=redis://localhost:6379

# ── Data sources ──────────────────────────────────────────────────────────────
TK_API_BASE=https://gegevensmagazijn.tweedekamer.nl/OData/v4/2.0
CACHE_TTL_TK=900
CACHE_TTL_STATIC=3600
